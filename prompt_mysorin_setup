#
# sorin テーマのラッパー。変更点は以下の 2 点のみ:
#   1. ディレクトリパスを省略せず完全表示（sorin はデフォルトで短縮する）
#   2. ディレクトリの色を cyan に変更（sorin のデフォルトは %F{4} blue）
#
# zprezto の sorin テーマ本体を直接呼び出すことで、
# sorin へのアップデートが自動的に反映される。
#

function prompt_mysorin_precmd {
  setopt LOCAL_OPTIONS
  unsetopt XTRACE KSH_ARRAYS

  # ディレクトリパスを省略せず完全表示（sorin の prompt-pwd による短縮を使わない）
  _prompt_sorin_pwd="%F{81}%~%f"

  # git リポジトリの切り替え検出（sorin と同じ処理）
  if (( $+functions[git-dir] )); then
    local new_git_root="$(git-dir 2> /dev/null)"
    if [[ $new_git_root != $_sorin_cur_git_root ]]; then
      _prompt_sorin_git=''
      _sorin_cur_git_root=$new_git_root
    fi
  fi

  # Python 仮想環境の情報を更新（sorin と同じ処理）
  if (( $+functions[python-info] )); then
    python-info
  fi

  # git 情報の非同期取得を開始（sorin の関数をそのまま使用）
  prompt_sorin_async_tasks
}

function prompt_mysorin_setup {
  # zprezto の sorin テーマを適用（git-info スタイル・エディタ情報・非同期処理をすべて引き継ぐ）
  autoload -Uz prompt_sorin_setup && prompt_sorin_setup "$@"

  # sorin の precmd フックを mysorin 版（フルパス表示）に差し替え
  add-zsh-hook -d precmd prompt_sorin_precmd
  add-zsh-hook    precmd prompt_mysorin_precmd

  # ディレクトリの色を cyan に変更（sorin のデフォルトは %F{4} blue）
  PROMPT='${SSH_TTY:+"%F{9}%n%f%F{7}@%f%F{3}%m%f "}%F{cyan}${_prompt_sorin_pwd}%(!. %B%F{1}#%f%b.)$ ${editor_info[keymap]} '
}

prompt_mysorin_setup "$@"
